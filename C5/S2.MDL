	Line {
	  SrcBlock		  "y"
	  SrcPort		  1
	  Points		  [35, 0; 0, -25]
	  DstBlock		  "Mux"
	  DstPort		  2
	}
	Line {
	  SrcBlock		  "x"
	  SrcPort		  1
	  Points		  [35, 0; 0, 30]
