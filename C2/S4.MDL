	  SrcPort		  1
	  Points		  [10, 0; 0, 20]
	  DstBlock		  "Sum"
	  DstPort		  1
	}
	Line {
	  SrcBlock		  "Relational\nOperator1"
	  SrcPort		  1
	  Points		  [10, 0; 0, -25]
	  DstBlock		  "Sum"
	  DstPort		  2
	}
	Line {
