	    DstBlock		    "Relational\nOperator1"
	    DstPort		    1
	  }
	  Branch {
	    DstBlock		    "Relational\nOperator"
	    DstPort		    1
	  }
	}
      }
    }
    Block {
      BlockType		      Sum
